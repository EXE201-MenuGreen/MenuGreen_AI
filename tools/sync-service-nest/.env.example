PORT=8099
SYNC_BATCH_SIZE=500
SYNC_ENABLED=true

# Backend source PostgreSQL (BE Docker DB)
BE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/menugreen

# PostgreSQL target (AI DB)
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/menugreen_ai

# Comma separated tables to sync. Leave empty to use default list in code.
SYNC_TABLES=
