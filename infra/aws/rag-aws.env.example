# Copy to infra/aws/rag-aws.env and update the values before running deploy_stack.sh

export AWS_REGION=ap-southeast-1
export AWS_ACCOUNT_ID=123456789012

export STACK_NAME=menugreen-rag-prod
export PROJECT_NAME=menugreen-rag
export ENVIRONMENT_NAME=prod
export ECR_REPO_NAME=menugreen-rag-runtime
export IMAGE_TAG=prod-20260630

# Networking
export VPC_ID=vpc-xxxxxxxx
export ALB_SUBNETS=subnet-aaaaaaaa,subnet-bbbbbbbb
export SERVICE_SUBNETS=subnet-aaaaaaaa,subnet-bbbbbbbb
export ASSIGN_PUBLIC_IP=ENABLED
export ALLOWED_INGRESS_CIDR=0.0.0.0/0

# Optional: lets CloudFormation add ingress from ECS tasks to your DB security group on 5432
export DB_SECURITY_GROUP_ID=sg-xxxxxxxx

# Optional: if you want HTTPS on the ALB
export ACM_CERTIFICATE_ARN=

# Secrets Manager ARNs
export POSTGRES_URL_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-1:123456789012:secret:menugreen/rag/postgres-url-xxxxx
export GOOGLE_API_KEY_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-1:123456789012:secret:menugreen/rag/google-api-key-xxxxx
export GOOGLE_API_KEYS_SECRET_ARN=
export AI_RUNTIME_INTERNAL_KEY_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-1:123456789012:secret:menugreen/rag/internal-key-xxxxx

# Runtime tuning
export DESIRED_COUNT=1
export TASK_CPU=1024
export TASK_MEMORY=2048
export CONTAINER_PORT=8000
export LOG_RETENTION_DAYS=14
export HEALTH_CHECK_PATH=/health
export DEBUG=false
export SERVE_FRONTEND=false
export INTENT_MODEL_DIR=models/intent_onnx
export GEMINI_QUERY_REWRITE_ENABLED=true
export GEMINI_RESPONSE_FALLBACK_ENABLED=true
